    <script>
        // --- Shared State ---
        let currentLang = 'en';
        
        // --- Helper Function: Calculate Significant Figures ---
        // Since our values are always >= 1.0 (no leading zeros before whole numbers)
        // the number of sig figs is simply the count of digits after removing the decimal point.
        function getSigFigsText(formattedNumberStr, isEn) {
            const digitsOnly = formattedNumberStr.replace('.', '');
            const count = digitsOnly.length;
            const digitsList = digitsOnly.split('').join(', ');
            return isEn ? `${count} digits (${digitsList})` : `${count} ตัว ได้แก่ ${digitsList}`;
        }

        // --- Language Toggle Logic ---
        function setLang(lang) {
            currentLang = lang;
            document.querySelectorAll('[data-en]').forEach(el => {
                el.innerHTML = el.getAttribute(`data-${lang}`);
            });

            const btnEn = document.getElementById('btn-lang-en');
            const btnTh = document.getElementById('btn-lang-th');

            if (lang === 'en') {
                btnEn.className = "px-6 py-2 text-base font-bold rounded-lg transition-all duration-300 bg-white text-blue-600 shadow-sm";
                btnTh.className = "px-6 py-2 text-base font-bold rounded-lg transition-all duration-300 text-slate-500 hover:text-slate-700 hover:bg-slate-200/50";
            } else {
                btnEn.className = "px-6 py-2 text-base font-bold rounded-lg transition-all duration-300 text-slate-500 hover:text-slate-700 hover:bg-slate-200/50";
                btnTh.className = "px-6 py-2 text-base font-bold rounded-lg transition-all duration-300 bg-white text-orange-500 shadow-sm";
            }

            if (!rIsAnimating) updateRulerSteps();
            if (!gIsAnimating) updateGaugeSteps();
            if (typeof vIsAnimating !== 'undefined' && !vIsAnimating) updateVolumeSteps();
            if (typeof tIsAnimating !== 'undefined' && !tIsAnimating && typeof tTargetTime !== 'undefined' && tTargetTime > 0) updateTimeSteps();
        }

        // ==========================================
        // RULER SIMULATOR LOGIC
        // ==========================================
        let rData = { cm: 0, mm: 0, est: 0, total: 0 };
        const rCanvas = document.getElementById('rulerCanvas');
        const rCtx = rCanvas.getContext('2d');
        const rContainer = document.getElementById('ruler-container');
        
        let rCurrentDraw = 0;
        let rTarget = 0;
        let rAnimId = null;
        let rIsAnimating = false;
        const R_MAX_CM = 15;

        function drawRulerScene() {
            const width = rCanvas.clientWidth;
            const height = 220;
            const pxPerCm = (width - 80) / R_MAX_CM; // 40px margin left/right

            rCtx.clearRect(0, 0, width, height);

            // Draw Object
            if (rCurrentDraw > 0) {
                const w = rCurrentDraw * pxPerCm;
                const grad = rCtx.createLinearGradient(40, 60, 40, 100);
                grad.addColorStop(0, '#60a5fa');
                grad.addColorStop(1, '#3b82f6');
                rCtx.fillStyle = grad;
                rCtx.beginPath();
                rCtx.roundRect(40, 60, w, 40, 4);
                rCtx.fill();
                rCtx.strokeStyle = '#1d4ed8';
                rCtx.lineWidth = 2;
                rCtx.stroke();
            }

            // Draw Ruler Base
            rCtx.fillStyle = '#fef3c7';
            rCtx.beginPath();
            rCtx.roundRect(20, 110, (R_MAX_CM * pxPerCm) + 40, 60, 6);
            rCtx.fill();
            rCtx.strokeStyle = '#1e293b';
            rCtx.lineWidth = 2;
            rCtx.stroke();

            // Draw Ruler Ticks
            rCtx.fillStyle = '#1e293b';
            rCtx.textAlign = 'center';
            for (let i = 0; i <= R_MAX_CM * 10; i++) {
                const x = 40 + (i * (pxPerCm / 10));
                rCtx.beginPath();
                rCtx.moveTo(x, 110);
                if (i % 10 === 0) {
                    rCtx.lineTo(x, 135); rCtx.lineWidth = 2; rCtx.stroke();
                    rCtx.font = 'bold 16px Inter'; rCtx.textBaseline = 'top';
                    rCtx.fillText(i / 10, x, 140);
                } else if (i % 5 === 0) {
                    rCtx.lineTo(x, 128); rCtx.lineWidth = 1.5; rCtx.stroke();
                } else {
                    rCtx.lineTo(x, 120); rCtx.lineWidth = 1; rCtx.stroke();
                }
            }
            rCtx.fillStyle = '#64748b'; rCtx.font = 'bold 14px Inter';
            rCtx.fillText('cm', 40 + (R_MAX_CM * pxPerCm) + 20, 140);

            // Draw Guide Line
            if (!rIsAnimating && rTarget > 0) {
                const gx = 40 + (rTarget * pxPerCm);
                rCtx.beginPath(); rCtx.setLineDash([5, 5]);
                rCtx.moveTo(gx, 40); rCtx.lineTo(gx, 150);
                rCtx.strokeStyle = '#ef4444'; rCtx.lineWidth = 2;
                rCtx.stroke(); rCtx.setLineDash([]);
            }
        }

        function animateRuler() {
            if (!rIsAnimating) return;
            const diff = rTarget - rCurrentDraw;
            if (Math.abs(diff) > 0.005) {
                rCurrentDraw += diff * 0.08;
                drawRulerScene();
                rAnimId = requestAnimationFrame(animateRuler);
            } else {
                rCurrentDraw = rTarget;
                rIsAnimating = false;
                drawRulerScene();
                updateRulerSteps();
            }
        }

        function generateNewObject() {
            if (rAnimId) cancelAnimationFrame(rAnimId);
            rData.cm = Math.floor(Math.random() * 12) + 2;
            rData.mm = Math.floor(Math.random() * 10);
            rData.est = Math.floor(Math.random() * 10);
            rData.total = rData.cm + (rData.mm / 10) + (rData.est / 100);
            
            rTarget = rData.total;
            rCurrentDraw = 0;
            
            document.getElementById('r-step1').innerText = '...';
            document.getElementById('r-step2').innerText = '...';
            document.getElementById('r-step3').innerText = '...';
            document.getElementById('r-final').innerText = '0.00';
            document.getElementById('r-sigfigs').innerText = '...';

            rIsAnimating = true;
            animateRuler();
        }

        function updateRulerSteps() {
            const { cm, mm, est, total } = rData;
            const isEn = currentLang === 'en';
            
            document.getElementById('r-step1').innerHTML = isEn
                ? `Passed whole number: <strong class="text-slate-800">${cm} cm</strong>.`
                : `วัตถุยืดเลยขีดเซนติเมตรที่: <strong class="text-slate-800">${cm} ซม.</strong>`;
            
            document.getElementById('r-step2').innerHTML = isEn
                ? `Passed <strong class="text-slate-800">${mm} mm</strong> lines (0.${mm} cm).<br>Certain: <strong class="text-blue-700">${cm}.${mm} cm</strong>.`
                : `เลยมาอีก <strong class="text-slate-800">${mm} ขีดเล็ก</strong> (0.${mm} ซม.)<br>ค่าที่แน่นอน: <strong class="text-blue-700">${cm}.${mm} ซม.</strong>`;
            
            document.getElementById('r-step3').innerHTML = isEn
                ? `Estimated gap is <strong class="text-orange-600">0.0${est} cm</strong>.`
                : `คาดคะเนระยะห่างได้ <strong class="text-orange-600">0.0${est} ซม.</strong>`;
            
            const finalStr = total.toFixed(2);
            document.getElementById('r-final').innerText = finalStr;
            document.getElementById('r-sigfigs').innerText = getSigFigsText(finalStr, isEn);
        }

        // ==========================================
        // GAUGE SIMULATOR LOGIC
        // ==========================================
        let gData = { major: 0, minor: 0, est: 0, total: 0 };
        const gCanvas = document.getElementById('gaugeCanvas');
        const gCtx = gCanvas.getContext('2d');
        const gContainer = document.getElementById('gauge-container');
        
        let gCurrentDraw = 0;
        let gTarget = 0;
        let gAnimId = null;
        let gIsAnimating = false;
        const G_MAX_PSI = 50;
        const G_START_ANGLE = Math.PI * 0.75; // 135 deg
        const G_SWEEP = Math.PI * 1.5; // 270 deg

        function drawGaugeScene() {
            const w = gCanvas.clientWidth;
            const h = gCanvas.clientHeight;
            gCtx.clearRect(0, 0, w, h);

            const cx = w / 2;
            const cy = h / 2 + 10;
            const r = Math.min(w, h) / 2 - 20;

            // Draw Dial Background
            gCtx.beginPath();
            gCtx.arc(cx, cy, r, 0, 2*Math.PI);
            gCtx.fillStyle = '#ffffff';
            gCtx.fill();
            gCtx.lineWidth = 6;
            gCtx.strokeStyle = '#cbd5e1'; // slate-300 rim
            gCtx.stroke();

            // Inner styling
            gCtx.beginPath();
            gCtx.arc(cx, cy, r - 6, 0, 2*Math.PI);
            gCtx.strokeStyle = '#f1f5f9';
            gCtx.lineWidth = 2;
            gCtx.stroke();

            // Draw Ticks & Labels
            for(let i = 0; i <= G_MAX_PSI; i++) {
                const angle = G_START_ANGLE + (i / G_MAX_PSI) * G_SWEEP;
                const isMajor = i % 10 === 0;
                const isHalf = i % 5 === 0;
                const innerR = isMajor ? r - 20 : (isHalf ? r - 15 : r - 8);

                gCtx.beginPath();
                gCtx.moveTo(cx + Math.cos(angle) * innerR, cy + Math.sin(angle) * innerR);
                gCtx.lineTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
                gCtx.lineWidth = isMajor ? 3 : (isHalf ? 2 : 1);
                gCtx.strokeStyle = isMajor ? '#1e293b' : '#64748b';
                gCtx.stroke();

                if(isMajor) {
                    gCtx.fillStyle = '#0f172a';
                    gCtx.font = 'bold 18px Inter';
                    gCtx.textAlign = 'center';
                    gCtx.textBaseline = 'middle';
                    const textR = r - 35;
                    gCtx.fillText(i.toString(), cx + Math.cos(angle) * textR, cy + Math.sin(angle) * textR);
                }
            }

            // Unit Label
            gCtx.fillStyle = '#64748b';
            gCtx.font = 'bold 14px Inter';
            gCtx.textAlign = 'center';
            gCtx.fillText('psi', cx, cy + r - 45);

            // Draw Target Guide Line (Ghost Needle) if not animating
            if (!gIsAnimating && gTarget > 0) {
                const targetAngle = G_START_ANGLE + (gTarget / G_MAX_PSI) * G_SWEEP;
                gCtx.beginPath();
                gCtx.moveTo(cx, cy);
                gCtx.lineTo(cx + Math.cos(targetAngle) * (r - 10), cy + Math.sin(targetAngle) * (r - 10));
                gCtx.lineWidth = 1;
                gCtx.setLineDash([4, 4]);
                gCtx.strokeStyle = '#f43f5e'; // rose-500
                gCtx.stroke();
                gCtx.setLineDash([]);
            }

            // Draw Active Needle
            const needleAngle = G_START_ANGLE + (gCurrentDraw / G_MAX_PSI) * G_SWEEP;
            gCtx.save();
            gCtx.translate(cx, cy);
            gCtx.rotate(needleAngle);
            
            // Needle shape
            gCtx.beginPath();
            gCtx.moveTo(0, -4);
            gCtx.lineTo(r - 15, 0); // tip
            gCtx.lineTo(0, 4);
            gCtx.lineTo(-15, 0); // tail
            gCtx.fillStyle = '#ef4444'; // red-500
            gCtx.fill();
            gCtx.restore();

            // Center Pin
            gCtx.beginPath();
            gCtx.arc(cx, cy, 8, 0, 2*Math.PI);
            gCtx.fillStyle = '#0f172a';
            gCtx.fill();
            gCtx.beginPath();
            gCtx.arc(cx, cy, 3, 0, 2*Math.PI);
            gCtx.fillStyle = '#94a3b8';
            gCtx.fill();
        }

        function animateGauge() {
            if (!gIsAnimating) return;
            const diff = gTarget - gCurrentDraw;
            if (Math.abs(diff) > 0.05) {
                gCurrentDraw += diff * 0.08;
                drawGaugeScene();
                gAnimId = requestAnimationFrame(animateGauge);
            } else {
                gCurrentDraw = gTarget;
                gIsAnimating = false;
                drawGaugeScene();
                updateGaugeSteps();
            }
        }

        function generateNewGauge() {
            if (gAnimId) cancelAnimationFrame(gAnimId);
            
            // Pick value between 5.0 and 45.0
            gData.major = (Math.floor(Math.random() * 4) + 1) * 10; // 10, 20, 30, 40
            gData.minor = Math.floor(Math.random() * 10); // 0 to 9
            gData.est = Math.floor(Math.random() * 10); // 0 to 9 tenths
            
            gData.total = gData.major + gData.minor + (gData.est / 10);
            gTarget = gData.total;
            gCurrentDraw = 0; // Starts from 0

            document.getElementById('g-step1').innerText = '...';
            document.getElementById('g-step2').innerText = '...';
            document.getElementById('g-step3').innerText = '...';
            document.getElementById('g-final').innerText = '0.0';
            document.getElementById('g-sigfigs').innerText = '...';

            gIsAnimating = true;
            animateGauge();
        }

        function updateGaugeSteps() {
            const { major, minor, est, total } = gData;
            const certain = major + minor;
            const isEn = currentLang === 'en';
            
            document.getElementById('g-step1').innerHTML = isEn
                ? `Needle passed major mark: <strong class="text-slate-800">${major} psi</strong>.`
                : `เข็มชี้เลยตัวเลขหลัก: <strong class="text-slate-800">${major} psi</strong>`;
            
            document.getElementById('g-step2').innerHTML = isEn
                ? `Passed <strong class="text-slate-800">${minor} small ticks</strong> (+${minor} psi).<br>Certain: <strong class="text-teal-700">${certain} psi</strong>.`
                : `เลยขีดเล็กมา <strong class="text-slate-800">${minor} ขีด</strong> (+${minor} psi)<br>ค่าที่แน่นอน: <strong class="text-teal-700">${certain} psi</strong>`;
            
            document.getElementById('g-step3').innerHTML = isEn
                ? `Estimated gap is <strong class="text-rose-600">0.${est} psi</strong>.`
                : `คาดคะเนระยะห่างได้ <strong class="text-rose-600">0.${est} psi</strong>`;
            
            const finalStr = total.toFixed(1);
            document.getElementById('g-final').innerText = finalStr;
            document.getElementById('g-sigfigs').innerText = getSigFigsText(finalStr, isEn);
        }

        // ==========================================
        // VOLUME SIMULATOR LOGIC
        // ==========================================
        let vData = { tens: 0, ones: 0, est: 0, total: 0 };
        const vCanvas = document.getElementById('volumeCanvas');
        const vCtx = vCanvas.getContext('2d');
        const vContainer = document.getElementById('volume-container');
        
        let vCurrentDraw = 0;
        let vTarget = 0;
        let vAnimId = null;
        let vIsAnimating = false;
        
        const V_MAX_ML = 50;
        const CYL_WIDTH = 90;
        const CYL_HEIGHT = 280;
        const CYL_BOTTOM_Y = 320;
        const MENISCUS_DEPTH = 12;

        function drawVolumeScene() {
            const w = vCanvas.clientWidth;
            const h = vCanvas.clientHeight;
            vCtx.clearRect(0, 0, w, h);

            const cx = w / 2;
            const pxPerMl = (CYL_HEIGHT - 30) / V_MAX_ML;

            // Draw Liquid
            if (vCurrentDraw > 0) {
                const liquidY = CYL_BOTTOM_Y - (vCurrentDraw * pxPerMl);
                
                // Liquid Body
                vCtx.fillStyle = 'rgba(168, 85, 247, 0.4)'; // purple-500 with opacity
                vCtx.beginPath();
                vCtx.moveTo(cx - CYL_WIDTH/2 + 2, CYL_BOTTOM_Y - 2);
                vCtx.lineTo(cx + CYL_WIDTH/2 - 2, CYL_BOTTOM_Y - 2);
                vCtx.lineTo(cx + CYL_WIDTH/2 - 2, liquidY - MENISCUS_DEPTH);
                
                // Meniscus Curve (reading taken at lowest point `liquidY`)
                vCtx.quadraticCurveTo(cx, liquidY + MENISCUS_DEPTH, cx - CYL_WIDTH/2 + 2, liquidY - MENISCUS_DEPTH);
                vCtx.fill();
                
                // Liquid top line (Meniscus outline)
                vCtx.beginPath();
                vCtx.moveTo(cx - CYL_WIDTH/2 + 2, liquidY - MENISCUS_DEPTH);
                vCtx.quadraticCurveTo(cx, liquidY + MENISCUS_DEPTH, cx + CYL_WIDTH/2 - 2, liquidY - MENISCUS_DEPTH);
                vCtx.strokeStyle = '#9333ea'; // purple-600
                vCtx.lineWidth = 3;
                vCtx.stroke();
            }

            // Draw Cylinder
            vCtx.beginPath();
            // Left wall
            vCtx.moveTo(cx - CYL_WIDTH/2, CYL_BOTTOM_Y - CYL_HEIGHT);
            vCtx.lineTo(cx - CYL_WIDTH/2, CYL_BOTTOM_Y);
            // Bottom
            vCtx.lineTo(cx + CYL_WIDTH/2, CYL_BOTTOM_Y);
            // Right wall
            vCtx.lineTo(cx + CYL_WIDTH/2, CYL_BOTTOM_Y - CYL_HEIGHT);
            
            // Lips
            vCtx.moveTo(cx - CYL_WIDTH/2 - 5, CYL_BOTTOM_Y - CYL_HEIGHT);
            vCtx.lineTo(cx - CYL_WIDTH/2 + 5, CYL_BOTTOM_Y - CYL_HEIGHT);
            vCtx.moveTo(cx + CYL_WIDTH/2 - 5, CYL_BOTTOM_Y - CYL_HEIGHT);
            vCtx.lineTo(cx + CYL_WIDTH/2 + 5, CYL_BOTTOM_Y - CYL_HEIGHT);

            vCtx.strokeStyle = '#cbd5e1'; // slate-300
            vCtx.lineWidth = 4;
            vCtx.stroke();

            // Glass Reflection
            vCtx.fillStyle = 'rgba(255, 255, 255, 0.4)';
            vCtx.fillRect(cx - CYL_WIDTH/2 + 5, CYL_BOTTOM_Y - CYL_HEIGHT + 10, 10, CYL_HEIGHT - 20);

            // Draw Ticks (10 mL to 50 mL)
            vCtx.fillStyle = '#1e293b';
            vCtx.textAlign = 'right';
            vCtx.textBaseline = 'middle';
            
            for (let i = 0; i <= V_MAX_ML; i++) {
                const y = CYL_BOTTOM_Y - (i * pxPerMl);
                const isMajor = i % 10 === 0;
                const isHalf = i % 5 === 0;
                
                vCtx.beginPath();
                vCtx.moveTo(cx - CYL_WIDTH/2, y);
                
                if (isMajor) {
                    vCtx.lineTo(cx - CYL_WIDTH/2 + 20, y);
                    vCtx.lineWidth = 2;
                    if(i > 0) { // Don't label 0
                        vCtx.font = 'bold 16px Inter';
                        vCtx.fillText(i, cx - CYL_WIDTH/2 - 10, y);
                    }
                } else if (isHalf) {
                    vCtx.lineTo(cx - CYL_WIDTH/2 + 15, y);
                    vCtx.lineWidth = 1.5;
                } else {
                    vCtx.lineTo(cx - CYL_WIDTH/2 + 10, y);
                    vCtx.lineWidth = 1;
                }
                vCtx.strokeStyle = '#475569';
                vCtx.stroke();
            }

            // Target Guide Line (Ghost Line at BOTTOM of meniscus)
            if (!vIsAnimating && vTarget > 0) {
                const targetY = CYL_BOTTOM_Y - (vTarget * pxPerMl);
                vCtx.beginPath();
                vCtx.moveTo(cx - CYL_WIDTH/2 - 30, targetY);
                vCtx.lineTo(cx + CYL_WIDTH/2 + 30, targetY);
                vCtx.lineWidth = 2;
                vCtx.setLineDash([6, 4]);
                vCtx.strokeStyle = '#f43f5e'; // rose-500
                vCtx.stroke();
                vCtx.setLineDash([]);
            }
        }

        function animateVolume() {
            if (!vIsAnimating) return;
            const diff = vTarget - vCurrentDraw;
            if (Math.abs(diff) > 0.05) {
                vCurrentDraw += diff * 0.1;
                drawVolumeScene();
                vAnimId = requestAnimationFrame(animateVolume);
            } else {
                vCurrentDraw = vTarget;
                vIsAnimating = false;
                drawVolumeScene();
                updateVolumeSteps();
            }
        }

        function generateNewVolume() {
            if (vAnimId) cancelAnimationFrame(vAnimId);
            
            // Value between 10.0 and 49.9
            vData.tens = (Math.floor(Math.random() * 4) + 1) * 10; // 10, 20, 30, 40
            vData.ones = Math.floor(Math.random() * 10); // 0 to 9
            vData.est = Math.floor(Math.random() * 10); // 0 to 9 tenths
            
            vData.total = vData.tens + vData.ones + (vData.est / 10);
            vTarget = vData.total;
            vCurrentDraw = 0; // Starts from empty

            document.getElementById('v-step1').innerText = '...';
            document.getElementById('v-step2').innerText = '...';
            document.getElementById('v-step3').innerText = '...';
            document.getElementById('v-final').innerText = '0.0';
            document.getElementById('v-sigfigs').innerText = '...';

            vIsAnimating = true;
            animateVolume();
        }

        function updateVolumeSteps() {
            const { tens, ones, est, total } = vData;
            const certain = tens + ones;
            const isEn = currentLang === 'en';
            
            document.getElementById('v-step1').innerHTML = isEn
                ? `Meniscus passed the tens mark: <strong class="text-slate-800">${tens} mL</strong>.`
                : `จุดต่ำสุดของน้ำเลยขีดหลักสิบที่: <strong class="text-slate-800">${tens} mL</strong>`;
            
            document.getElementById('v-step2').innerHTML = isEn
                ? `Passed <strong class="text-slate-800">${ones} small ticks</strong> (+${ones} mL).<br>Certain: <strong class="text-purple-700">${certain} mL</strong>.`
                : `เลยขีดเล็กมา <strong class="text-slate-800">${ones} ขีด</strong> (+${ones} mL)<br>ค่าที่แน่นอน: <strong class="text-purple-700">${certain} mL</strong>`;
            
            document.getElementById('v-step3').innerHTML = isEn
                ? `Estimated gap is <strong class="text-rose-600">0.${est} mL</strong>.`
                : `คาดคะเนระยะห่างได้ <strong class="text-rose-600">0.${est} mL</strong>`;
            
            const finalStr = total.toFixed(1);
            document.getElementById('v-final').innerText = finalStr;
            document.getElementById('v-sigfigs').innerText = getSigFigsText(finalStr, isEn);
        }

        // ==========================================
        // TIME SIMULATOR LOGIC
        // ==========================================
        let tTargetTime = 0; // True time A to B
        const tCanvas = document.getElementById('timeCanvas');
        const tCtx = tCanvas.getContext('2d');
        const tContainer = document.getElementById('time-container');
        
        let tCurrentTimer = 0; // Displayed time on watch
        let tAnimId = null;
        let tIsAnimating = false;
        let tStartTime = 0;
        
        // Physics logic variables
        let trackStartX, trackEndX, pointAX, pointBX, distAB, velocity, timeToA, timeTotal;

        function drawTimeScene(elapsedSec, timerValue) {
            const w = tCanvas.clientWidth;
            const h = tCanvas.clientHeight;
            tCtx.clearRect(0, 0, w, h);

            // Calculate layout dynamics if not set
            trackStartX = 40;
            trackEndX = w - 40;
            pointAX = 100;
            pointBX = w - 100;
            distAB = pointBX - pointAX;

            // 1. Draw Track & Object
            const trackY = 80;

            // Track line
            tCtx.beginPath();
            tCtx.moveTo(20, trackY);
            tCtx.lineTo(w - 20, trackY);
            tCtx.lineWidth = 4;
            tCtx.strokeStyle = '#cbd5e1'; // slate-300
            tCtx.stroke();

            // Point A and B Markers
            tCtx.fillStyle = '#f43f5e'; // rose-500
            tCtx.font = 'bold 16px Inter';
            tCtx.textAlign = 'center';
            
            // Marker A
            tCtx.fillRect(pointAX - 2, trackY - 20, 4, 40);
            tCtx.fillText('A', pointAX, trackY - 30);
            
            // Marker B
            tCtx.fillRect(pointBX - 2, trackY - 20, 4, 40);
            tCtx.fillText('B', pointBX, trackY - 30);

            // Determine object position
            let objX = trackStartX;
            if (tTargetTime > 0) {
                velocity = distAB / tTargetTime;
                objX = trackStartX + (velocity * elapsedSec);
                if (objX > trackEndX) objX = trackEndX;
            }

            // Object (Box)
            tCtx.fillStyle = '#3b82f6'; // blue-500
            tCtx.beginPath();
            tCtx.roundRect(objX - 15, trackY - 15, 30, 30, 6);
            tCtx.fill();
            tCtx.strokeStyle = '#1e3a8a';
            tCtx.lineWidth = 2;
            tCtx.stroke();

            // 2. Draw Digital Stopwatch Face
            const cx = w / 2;
            const cy = 210;

            // Stopwatch body
            tCtx.fillStyle = '#1e293b'; // slate-800
            tCtx.beginPath();
            tCtx.roundRect(cx - 100, cy - 40, 200, 80, 16);
            tCtx.fill();
            
            // Stopwatch screen
            tCtx.fillStyle = '#0f172a'; // slate-900
            tCtx.beginPath();
            tCtx.roundRect(cx - 85, cy - 25, 170, 50, 8);
            tCtx.fill();
            tCtx.strokeStyle = '#334155';
            tCtx.lineWidth = 2;
            tCtx.stroke();

            // Stopwatch buttons (Top)
            tCtx.fillStyle = '#ef4444'; // Red button
            tCtx.fillRect(cx - 40, cy - 50, 20, 10);
            tCtx.fillStyle = '#3b82f6'; // Blue button
            tCtx.fillRect(cx + 20, cy - 50, 20, 10);

            // Digital Text
            tCtx.fillStyle = '#22c55e'; // green-500
            tCtx.font = 'bold 36px monospace';
            tCtx.textAlign = 'center';
            tCtx.textBaseline = 'middle';
            
            // Format time as 00.00
            let timeStr = timerValue.toFixed(2);
            if (timerValue < 10) timeStr = "0" + timeStr;
            
            tCtx.fillText(timeStr, cx, cy);
            
            // Label
            tCtx.fillStyle = '#64748b';
            tCtx.font = '12px Inter';
            tCtx.fillText('SEC', cx + 60, cy + 12);
        }

        function animateTime(timestamp) {
            if (!tIsAnimating) return;
            
            let elapsedSec = (timestamp - tStartTime) / 1000;
            
            // Recalculate parameters continuously in case of resize
            velocity = distAB / tTargetTime;
            timeToA = (pointAX - trackStartX) / velocity;
            timeTotal = (trackEndX - trackStartX) / velocity;

            // Timer logic: Starts at A, Stops at B
            if (elapsedSec < timeToA) {
                tCurrentTimer = 0; // Not at A yet
            } else if (elapsedSec < timeToA + tTargetTime) {
                tCurrentTimer = elapsedSec - timeToA; // Between A and B
            } else {
                tCurrentTimer = tTargetTime; // Passed B
            }
            
            // Stop animation when reaching the far right
            if (elapsedSec >= timeTotal) {
                tIsAnimating = false;
                drawTimeScene(timeTotal, tCurrentTimer);
                updateTimeSteps();
            } else {
                drawTimeScene(elapsedSec, tCurrentTimer);
                tAnimId = requestAnimationFrame(animateTime);
            }
        }

        function startNewTime() {
            if (tAnimId) cancelAnimationFrame(tAnimId);
            
            // Generate random transit time between 2.00s and 6.00s
            tTargetTime = (Math.random() * 4 + 2);
            tTargetTime = parseFloat(tTargetTime.toFixed(2));
            
            tCurrentTimer = 0;

            document.getElementById('t-step1').innerText = '...';
            document.getElementById('t-step2').innerText = '...';
            document.getElementById('t-step3').innerText = '...';
            document.getElementById('t-final').innerText = '0.00';
            document.getElementById('t-sigfigs').innerText = '...';

            // Draw initial state
            drawTimeScene(0, 0);
            
            // Wait slightly before moving
            setTimeout(() => {
                tStartTime = performance.now();
                tIsAnimating = true;
                requestAnimationFrame(animateTime);
            }, 500);
        }

        function updateTimeSteps() {
            const isEn = currentLang === 'en';
            
            document.getElementById('t-step1').innerHTML = isEn
                ? `The digital screen shows exactly: <strong class="text-slate-800">${tTargetTime.toFixed(2)} s</strong>.`
                : `อ่านค่าที่ปรากฏบนหน้าปัดดิจิทัลได้: <strong class="text-slate-800">${tTargetTime.toFixed(2)} วิ</strong>`;
            
            document.getElementById('t-step2').innerHTML = isEn
                ? `Digital tools have ±0.01s error, but human reaction (pressing start/stop) dominates at <strong class="text-rose-600">±0.20 s</strong>.`
                : `หน้าจอดิจิทัลละเอียดระดับ 0.01 วิ แต่การกดเริ่ม/หยุดด้วยมือ มีความคลาดเคลื่อนจากปฏิกิริยาบุคคลเป็นหลัก <strong class="text-rose-600">±0.20 วิ</strong>`;
            
            document.getElementById('t-step3').innerHTML = isEn
                ? `Combine reading with human error: <strong class="text-orange-600">${tTargetTime.toFixed(2)} ± 0.20 s</strong>.`
                : `บันทึกค่าที่อ่านได้ ร่วมกับความคลาดเคลื่อนจากคน: <strong class="text-orange-600">${tTargetTime.toFixed(2)} ± 0.20 วิ</strong>`;
            
            const finalStr = tTargetTime.toFixed(2);
            document.getElementById('t-final').innerText = finalStr;
            document.getElementById('t-sigfigs').innerText = getSigFigsText(finalStr, isEn);
        }

        // ==========================================
        // SYSTEM INIT & RESIZE
        // ==========================================
        function resizeCanvases() {
            const dpr = window.devicePixelRatio || 1;

            // Ruler
            const rWidth = rContainer.clientWidth;
            rCanvas.width = rWidth * dpr;
            rCanvas.height = 220 * dpr;
            rCanvas.style.width = rWidth + 'px';
            rCanvas.style.height = 220 + 'px';
            rCtx.scale(dpr, dpr);
            drawRulerScene();

            // Gauge
            const gSize = gCanvas.clientWidth; 
            gCanvas.width = gSize * dpr;
            gCanvas.height = gSize * dpr;
            gCtx.scale(dpr, dpr);
            drawGaugeScene();

            // Volume
            const vWidth = vContainer.clientWidth;
            vCanvas.width = vWidth * dpr;
            vCanvas.height = 350 * dpr;
            vCanvas.style.width = vWidth + 'px';
            vCanvas.style.height = 350 + 'px';
            vCtx.scale(dpr, dpr);
            drawVolumeScene();

            // Time
            const tWidth = tContainer.clientWidth;
            tCanvas.width = tWidth * dpr;
            tCanvas.height = 300 * dpr;
            tCanvas.style.width = tWidth + 'px';
            tCanvas.style.height = 300 + 'px';
            tCtx.scale(dpr, dpr);
            if (tTargetTime === 0) drawTimeScene(0, 0); 
            else drawTimeScene((trackEndX - trackStartX)/(distAB/tTargetTime), tTargetTime);
        }

        window.addEventListener('resize', resizeCanvases);

        window.onload = () => {
            setLang('en');
            // Wait slightly for layout to settle before sizing canvas
            setTimeout(() => {
                resizeCanvases();
                generateNewObject();
                generateNewGauge();
                generateNewVolume();
                drawTimeScene(0); // Init Time canvas
            }, 50);
        };
    </script>
</body>
